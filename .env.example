# Copiar a .env y completar con valores reales (el .env no se versiona).
# Sin .env, compose usa los defaults de desarrollo (travian/root).
# Ojo: MariaDB solo aplica estas variables al inicializar el volumen dbdata;
# si la base ya existe, deben coincidir con la contraseña ya creada.
MARIADB_PASSWORD=cambiame
MARIADB_ROOT_PASSWORD=cambiame-root
